# Copy this file to .env and replace every placeholder before running the app.

# PostgreSQL credentials used by docker-compose and local development.
POSTGRES_USER=automaton
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=automaton_dev

# Phoenix/Ecto connection string for the application runtime.
DATABASE_URL=ecto://automaton:change_me_to_a_long_random_password@localhost/automaton_dev

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=replace_with_a_generated_secret_key_base

# Hostname and port Phoenix should bind/use in generated URLs.
PHX_HOST=localhost
PORT=4000

# Anthropic API key for LLM calls.
ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key
